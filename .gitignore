# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Built binary - do not commit the executable
sub-maker
sub-maker-*

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Log files
*.log

# Temporary files from builds or tests
/tmp/
*.tmp

# Environment or local config that might contain secrets
.env
.env.local
config.local.yaml

# Demo output paths (from SUB_MAKER_DEMO)
sub-maker-demo-etc/
